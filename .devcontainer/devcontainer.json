{
  "name": "fomc-sentiment-spy",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance",
        "anthropic.claude-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.askForKernelRestart": false
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && python -m ipykernel install --user --name fomc --display-name 'Python (fomc)' && npm install -g @anthropic-ai/claude-code",
  "remoteUser": "vscode"
}
